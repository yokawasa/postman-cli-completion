#compdef postman
compdef _postman postman
# Zsh completion for Postman CLI (postman v1.35.2)
# https://github.com/yokawasa/postman-cli-completion

_postman() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -C \
    '(-v --version)'{-v,--version}'[output the version number]' \
    '--silent[silence all terminal output]' \
    '--color[enable/disable colored output]:mode:(auto on off)' \
    '(-h --help)'{-h,--help}'[display help]' \
    '1: :_postman_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $words[1] in
        login)        _postman_login ;;
        logout)       _postman_logout ;;
        collection)   _postman_collection ;;
        api)          _postman_api ;;
        runner)       _postman_runner ;;
        spec)         _postman_spec ;;
        monitor)      _postman_monitor ;;
        workspace)    _postman_workspace ;;
        performance)  _postman_performance ;;
        flows|fl)     _postman_flows ;;
        request)      _postman_request ;;
        sdk)          _postman_sdk ;;
        mock)         _postman_mock ;;
        application|app) _postman_application ;;
        simulate)     _postman_simulate ;;
      esac
      ;;
  esac
}

_postman_commands() {
  local -a commands
  commands=(
    'login:Authenticate with Postman'
    'logout:Delete the stored Postman API key'
    'collection:Run and test Postman collections'
    'api:Publish and test APIs (US region only)'
    'runner:Run runners on your own environments'
    'spec:Lint and validate Specifications'
    'monitor:Invoke a monitor run and display results'
    'workspace:Manage workspace resources'
    'performance:Manage performance tests on collections'
    'flows:Manage and interact with flows'
    'fl:Alias for flows'
    'request:Send HTTP requests from the command line'
    'sdk:Generate and manage SDKs'
    'mock:Run and manage local mock servers'
    'application:Application-level commands (init, test)'
    'app:Alias for application'
    'simulate:Start mock servers with simulated failures'
  )
  _describe -t commands 'postman command' commands
}

_postman_login() {
  _arguments \
    '--alias[Specify the alias of the API key]:alias' \
    '--with-api-key[Specify the API key directly]:apikey' \
    '--region[Specify the region for authentication]:region:(us eu)' \
    '--verbose[Show detailed error information]' \
    '(-h --help)'{-h,--help}'[display help]'
}

_postman_logout() {
  _arguments \
    '--alias[Specify the alias of the API key]:alias' \
    '(-h --help)'{-h,--help}'[display help]'
}

_postman_collection() {
  local context state state_descr line
  typeset -A opt_args
  _arguments -C \
    '(-h --help)'{-h,--help}'[display help]' \
    '1: :_postman_collection_commands' \
    '*::arg:->args'
  case $state in
    args)
      case $words[1] in
        migrate) _postman_collection_migrate ;;
        lint)    _postman_collection_lint ;;
        run)     _postman_collection_run ;;
      esac
      ;;
  esac
}

_postman_collection_commands() {
  local -a sub
  sub=(
    'migrate:Migrate a v2.1 collection to the v3 format'
    'lint:Run linting on a local v3 collection'
    'run:Initiate a Postman collection run'
  )
  _describe -t commands 'collection command' sub
}

_postman_collection_migrate() {
  _arguments \
    '(-h --help)'{-h,--help}'[display help]' \
    '*:path:_files -g "*.(json|JSON)"'
}

_postman_collection_lint() {
  _arguments \
    '(-h --help)'{-h,--help}'[display help]' \
    '*:path:_files -g "*.(json|JSON)"'
}

_postman_collection_run() {
  _arguments \
    '(-e --environment)'{-e,--environment}'[Postman Environment ID or path]:path:_files -g "*.(json|JSON)"' \
    '(-g --globals)'{-g,--globals}'[Postman Globals file path]:path:_files -g "*.(json|JSON)"' \
    '(-r --reporters)'{-r,--reporters}'[Reporters to use]:reporter:(cli json junit html)' \
    '--reporter-json-export[Path to save JSON report]:path:_files' \
    '--reporter-junit-export[Path to save JUnit report]:path:_files' \
    '--reporter-html-export[Path to save HTML report]:path:_files' \
    '--reporter-json-structure[Generate JSON report using a specific schema]:schema:(newman)' \
    '--reporter-json-omitRequestBodies[Remove request bodies from JSON report]' \
    '--reporter-json-omitResponseBodies[Remove response bodies from JSON report]' \
    '--reporter-json-omitHeaders[Remove headers from JSON report]' \
    '--reporter-json-omitAllHeadersAndBody[Remove headers and bodies from JSON report]' \
    '--reporter-html-omitRequestBodies[Remove request bodies from HTML report]' \
    '--reporter-html-omitResponseBodies[Remove response bodies from HTML report]' \
    '--reporter-html-omitHeaders[Remove headers from HTML report]' \
    '--reporter-html-omitAllHeadersAndBody[Remove headers and bodies from HTML report]' \
    '(-n --iteration-count)'{-n,--iteration-count}'[Number of iterations to run]:n' \
    '(-d --iteration-data)'{-d,--iteration-data}'[Path to iteration data (JSON or CSV)]:path:_files -g "*.(json|csv|JSON|CSV)"' \
    '-i[Specify request/folder id, name, or path]:id' \
    '--global-var[Specify a global variable key=value]:kv' \
    '--env-var[Specify an environment variable key=value]:kv' \
    '--integration-id[Specify the integration id for the report]:id' \
    '--postman-api-key[Postman API key]:apikey' \
    '--alias[Specify the alias of the API key]:alias' \
    '--bail[Stop run on error]:modifiers' \
    '--ignore-redirects[Do not follow 3XX redirects]' \
    '(-x --suppress-exit-code)'{-x,--suppress-exit-code}'[Override default exit code]' \
    '--silent[Suppress CLI output]' \
    '--disable-unicode[Replace Unicode symbols with plain text]' \
    '--delay-request[Delay between requests in ms]:n' \
    '--timeout[Timeout for collection run in ms]:n' \
    '--timeout-request[Timeout for requests in ms]:n' \
    '--timeout-script[Timeout for scripts in ms]:n' \
    '--working-dir[Path to the working directory]:path:_files -/' \
    '--no-insecure-file-read[Prevent reading files outside the working directory]' \
    '(-k --insecure)'{-k,--insecure}'[Disable SSL validations]' \
    '--ssl-client-cert-list[Path to client cert configurations (JSON)]:path:_files -g "*.(json|JSON)"' \
    '--ssl-client-cert[Path to client certificate (PEM)]:path:_files -g "*.(pem|crt|cer|PEM|CRT|CER)"' \
    '--ssl-client-key[Path to client cert private key]:path:_files -g "*.(pem|key|PEM|KEY)"' \
    '--ssl-client-passphrase[Client cert passphrase]:passphrase' \
    '--ssl-extra-ca-certs[Additional trusted CA certs (PEM)]:path:_files -g "*.(pem|crt|cer|PEM|CRT|CER)"' \
    '--cookie-jar[Path to a custom cookie jar]:path:_files -g "*.(json|JSON)"' \
    '--export-cookie-jar[Path to export the cookie jar]:path:_files' \
    '--verbose[Show detailed run information]' \
    '--mock[Start a mock server from manifest file]:path:_files -g "*.(json|JSON)"' \
    '--simulate[Start mock with fault-injection scenarios]:path:_files -g "*.(sim.yaml|sim.yml|yaml|yml|YAML|YML)"' \
    '(-h --help)'{-h,--help}'[display help]' \
    '*:collectionId or path:_files -g "*.(json|JSON)"'
}

