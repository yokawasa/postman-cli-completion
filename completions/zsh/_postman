  typeset -A opt_args
  _arguments -C \
    '(-h --help)'{-h,--help}'[display help]' \
    '1: :_postman_sdk_commands' \
    '*::arg:->args'
  case $state in
    args)
      case $words[1] in
        init)            _arguments '(-h --help)'{-h,--help}'[display help]' ;;
        generate|build)  _arguments '(-h --help)'{-h,--help}'[display help]' '(-l --languages)'{-l,--languages}'[Target languages]:lang' '(-o --output)'{-o,--output}'[Output directory]:path:_files -/' '--all[Generate all languages]' '*:idOrPath:_files' ;;
        track)           _arguments '(-h --help)'{-h,--help}'[display help]' ;;
        list|ls)         _arguments '(-h --help)'{-h,--help}'[display help]' '*:id:' ;;
        fetch|get)       _arguments '(-h --help)'{-h,--help}'[display help]' '*:buildId:' ;;
        connect)         _arguments '(-h --help)'{-h,--help}'[display help]' '1:provider:(github gitlab bitbucket)' '2:id:' ;;
      esac
      ;;
  esac
}

